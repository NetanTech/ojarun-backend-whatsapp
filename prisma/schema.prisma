// Ojarun — Prisma schema (Phase 1, slim)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Channel {
  whatsapp
  web
  app
}

enum OrderStatus {
  pending
  confirmed
  shopping
  purchased
  dispatched
  delivered
  cancelled
}

enum MessageDirection {
  inbound
  outbound
}

enum ConversationMode {
  bot
  human
}

// ─── Customers ────────────────────────────────────────────────────────────────

model Customer {
  id             String   @id @default(uuid()) @db.Uuid
  whatsappNumber String   @unique @map("whatsapp_number")
  name           String?
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  orders        Order[]
  messages      Message[]
  conversations Conversation[]

  @@map("customers")
}

// ─── Products ─────────────────────────────────────────────────────────────────

model Product {
  id           String   @id @default(uuid()) @db.Uuid
  name         String
  unit         String
  currentPrice Decimal  @map("current_price") @db.Decimal(12, 2)
  isAvailable  Boolean  @default(true) @map("is_available")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  orderItems OrderItem[]

  @@map("products")
}

// ─── Orders ───────────────────────────────────────────────────────────────────

model Order {
  id            String      @id @default(uuid()) @db.Uuid
  customerId    String      @map("customer_id") @db.Uuid
  channel       Channel     @default(whatsapp)
  status        OrderStatus @default(pending)
  total         Decimal     @default(0) @db.Decimal(12, 2)
  customerNotes String?     @map("customer_notes")
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)

  customer Customer    @relation(fields: [customerId], references: [id])
  items    OrderItem[]

  @@index([customerId])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id                  String   @id @default(uuid()) @db.Uuid
  orderId             String   @map("order_id") @db.Uuid
  productId           String?  @map("product_id") @db.Uuid
  productNameSnapshot String   @map("product_name_snapshot")
  unitSnapshot        String   @map("unit_snapshot")
  unitPriceSnapshot   Decimal  @map("unit_price_snapshot") @db.Decimal(12, 2)
  quantity            Decimal  @db.Decimal(12, 3)
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@map("order_items")
}

// ─── Messages ─────────────────────────────────────────────────────────────────

model Message {
  id                String           @id @default(uuid()) @db.Uuid
  customerId        String           @map("customer_id") @db.Uuid
  whatsappMessageId String?          @unique @map("whatsapp_message_id")
  direction         MessageDirection
  body              String?
  raw               Json
  createdAt         DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId, createdAt])
  @@map("messages")
}

// ─── Conversations ────────────────────────────────────────────────────────────

model Conversation {
  id         String           @id @default(uuid()) @db.Uuid
  customerId String           @unique @map("customer_id") @db.Uuid
  mode       ConversationMode @default(bot)
  state      Json             @default("{}")
  createdAt  DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("conversations")
}
