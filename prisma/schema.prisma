generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Customer {
  id                      String         @id @default(uuid()) @db.Uuid
  whatsappNumber          String         @unique @map("whatsapp_number")
  name                    String?
  createdAt               DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  conversations           conversations?
  messages                Message[]
  orders                  Order[]
  chatSessions            ChatSession[]
  contextSummary          String?        @map("context_summary")
  contextSummaryUpdatedAt DateTime?      @map("context_summary_updated_at") @db.Timestamptz(6)

  @@map("customers")
}

model Product {
  id           String      @id @default(uuid()) @db.Uuid
  name         String
  unit         String
  currentPrice Decimal     @map("current_price") @db.Decimal(12, 2)
  isAvailable  Boolean     @default(true) @map("is_available")
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  orderItems   OrderItem[]

  @@map("products")
}

model Order {
  id            String      @id @default(uuid()) @db.Uuid
  customerId    String      @map("customer_id") @db.Uuid
  channel       Channel     @default(whatsapp)
  status        OrderStatus @default(pending)
  total         Decimal     @default(0) @db.Decimal(12, 2)
  customerNotes String?     @map("customer_notes")
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  items         OrderItem[]
  customer      Customer    @relation(fields: [customerId], references: [id])

  @@index([customerId])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id                  String   @id @default(uuid()) @db.Uuid
  orderId             String   @map("order_id") @db.Uuid
  productId           String?  @map("product_id") @db.Uuid
  productNameSnapshot String   @map("product_name_snapshot")
  unitSnapshot        String   @map("unit_snapshot")
  unitPriceSnapshot   Decimal  @map("unit_price_snapshot") @db.Decimal(12, 2)
  quantity            Decimal  @db.Decimal(12, 3)
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  order               Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product             Product? @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@map("order_items")
}

model Message {
  id                String           @id @default(uuid()) @db.Uuid
  customerId        String           @map("customer_id") @db.Uuid
  sessionId         String?          @map("session_id") @db.Uuid
  whatsappMessageId String?          @unique @map("whatsapp_message_id")
  direction         MessageDirection
  body              String?
  raw               Json
  createdAt         DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  customer          Customer         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  session           ChatSession?     @relation(fields: [sessionId], references: [id])

  @@index([customerId, createdAt])
  @@index([sessionId, createdAt])
  @@map("messages")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model conversations {
  id          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customer_id String           @unique @db.Uuid
  mode        ConversationMode @default(bot)
  state       Json             @default("{}")
  created_at  DateTime         @default(now()) @db.Timestamptz(6)
  updated_at  DateTime         @default(now()) @db.Timestamptz(6)
  customers   Customer         @relation(fields: [customer_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([customer_id])
}

/// Per-session message grouping for AI context + a rolling customer summary.
/// Distinct from `conversations` above, which is a bot/human handoff toggle.
model ChatSession {
  id                   String            @id @default(uuid()) @db.Uuid
  customerId           String            @map("customer_id") @db.Uuid
  customer             Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  status               ChatSessionStatus @default(active)
  startedAt            DateTime          @default(now()) @map("started_at") @db.Timestamptz(6)
  lastActivityAt       DateTime          @default(now()) @map("last_activity_at") @db.Timestamptz(6)
  closedAt             DateTime?         @map("closed_at") @db.Timestamptz(6)
  summary              String?
  draftItems           Json?             @map("draft_items")
  draftDeliveryAddress String?           @map("draft_delivery_address")
  messages             Message[]

  @@index([customerId, status])
  @@index([lastActivityAt])
  @@map("chat_sessions")
}

model BotResponse {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key       String   @unique
  body      String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("bot_responses")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model PendingOrder {
  id         String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  phone      String    @unique
  startedAt  DateTime  @default(now()) @map("started_at") @db.Timestamptz(6)
  remindedAt DateTime? @map("reminded_at") @db.Timestamptz(6)
  completed  Boolean   @default(false)

  @@map("pending_orders")
}

enum Channel {
  whatsapp
  web
  app
}

enum OrderStatus {
  pending
  confirmed
  shopping
  purchased
  dispatched
  delivered
  cancelled
}

enum MessageDirection {
  inbound
  outbound
}

enum ConversationMode {
  bot
  human
}

enum ChatSessionStatus {
  active
  closed
}