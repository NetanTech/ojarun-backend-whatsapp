# ─── App ────────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Supabase Postgres ──────────────────────────────────────────────────────────
# In Supabase dashboard → Project Settings → Database → Connection string.
# DATABASE_URL: "Transaction" pooler (port 6543) — for runtime queries.
# DIRECT_URL:   direct connection (port 5432) — Prisma needs this for migrations.
# Replace <password> with your DB password (URL-encode special chars).
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# ─── WhatsApp Cloud API (Meta) ──────────────────────────────────────────────────
# All from developers.facebook.com → your app → WhatsApp.
#
# WHATSAPP_VERIFY_TOKEN: any random string YOU choose. Paste the same value
#   into Meta's webhook config; we check it on GET /webhooks/whatsapp.
# WHATSAPP_APP_SECRET: App settings → Basic → App Secret.
#   Used to validate X-Hub-Signature-256 on inbound webhooks. NEVER skip in prod.
# WHATSAPP_ACCESS_TOKEN: System User permanent token (NOT the temp 24h one).
# WHATSAPP_PHONE_NUMBER_ID: WhatsApp → API Setup → "From" phone number ID.
# WHATSAPP_API_VERSION: Meta's Graph API version, e.g. v21.0.
WHATSAPP_VERIFY_TOKEN=replace-me-with-a-long-random-string
WHATSAPP_APP_SECRET=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v21.0
